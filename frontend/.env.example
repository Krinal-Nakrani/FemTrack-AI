# ============================================
# FemTrack AI — Frontend Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ============================================

# ----- Firebase Configuration -----
# Get these from: https://console.firebase.google.com
# → Your Project → Project Settings → General → Your Apps → Web App
VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=femtrack-ai.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=femtrack-ai
VITE_FIREBASE_STORAGE_BUCKET=femtrack-ai.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef

# ----- Firebase Cloud Messaging (Push Notifications) -----
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push Certificates
VITE_FIREBASE_VAPID_KEY=BKeXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ----- Client-Side Encryption -----
# Generate a strong random key (minimum 32 chars). Used for AES-256 encryption of user data before Firestore writes.
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# ----- Backend API URL -----
# Only needed if NOT using the Vite dev proxy (vite.config.ts already proxies /api → localhost:8000)
VITE_API_BASE_URL=http://localhost:8000
VITE_PUBLIC_GEMINI_API_KEY=mdnjuf0-9uhds......
VITE_GROQ_API_KEY=lckvndfo23456...