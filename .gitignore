# ============================================
#  FemTrack AI — .gitignore
# ============================================

# ----- Environment & Secrets -----
# Block ALL .env files everywhere (frontend + backend)
.env
.env.local
.env.*.local

# BUT always track .env.example files (templates for contributors)
!.env.example
!frontend/.env.example
!backend/.env.example

# Other secrets
*.pem
*.key
firebase-service-account.json

# ----- Frontend (Node / Vite) -----
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.tsbuildinfo
frontend/*.tsbuildinfo

# ----- Backend (Python) -----
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/.venv/
backend/venv/
backend/env/
backend/.env
backend/saved_models/
backend/data/synthetic_pcod_data.csv

# ----- IDE & OS -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ----- Logs & Debug -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Build Artifacts -----
*.tgz
*.tar.gz
coverage/
.nyc_output/

# ----- PWA Generated -----
frontend/dev-dist/
