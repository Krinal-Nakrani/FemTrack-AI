# ============================================
# FemTrack AI — Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ============================================

# ----- Server Configuration -----
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ----- CORS Allowed Origins -----
# Comma-separated list of frontend URLs allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ----- Firebase Admin SDK (optional — for server-side auth verification) -----
# Download service account JSON from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ----- Model Configuration -----
MODEL_DIR=./saved_models
SYNTHETIC_DATA_SAMPLES=2000
